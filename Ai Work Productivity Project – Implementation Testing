  <script>
    document.getElementById("year").textContent = new Date().getFullYear();

    const sample = `"use strict";

const prompt = require("prompt-sync")();

while (true) {
  const answer = prompt("Do you want to do a calculation? (Y/N) ").toUpperCase();

  if (answer === "N") {
    console.log("Goodbye!");
    break;
  }

  if (answer !== "Y") {
    console.log("Please type Y or N.");
    continue;
  }

  const num1 = Number(prompt("What is the first number? "));
  const op = prompt("Which operation (+, -, *, /)? ").trim();
  const num2 = Number(prompt("What is the second number? "));

  if (Number.isNaN(num1) || Number.isNaN(num2)) {
    console.log("Please enter valid numbers.");
    continue;
  }

  if (op === "/" && num2 === 0) {
    console.log("Division by 0 is not allowed.");
    continue;
  }

  let result;

  if (op === "+") result = num1 + num2;
  else if (op === "-") result = num1 - num2;
  else if (op === "*") result = num1 * num2;
  else if (op === "/") result = num1 / num2;
  else {
    console.log("Unknown operation. Use +, -, *, or /.");
    continue;
  }

  console.log(\`\${num1} \${op} \${num2} = \${result}\`);
}`;

    function copySnippet() {
      navigator.clipboard.writeText(sample);
      alert("Code snippet gekopieerd!");
